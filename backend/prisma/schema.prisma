generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String    @unique
  password  String
  patterns  Pattern[] @relation("UserPatterns")
  projects  Project[] @relation("UserProjects")
}

model Pattern {
  id                Int              @id @default(autoincrement())
  name              String
  description       String?
  text              String           @db.Text
  user              User             @relation("UserPatterns", fields: [userId], references: [id])
  userId            Int
  points            Point[]
  projectPatterns   ProjectPattern[]
  createdAt         DateTime         @default(now())
}

model Project {
  id                Int              @id @default(autoincrement())
  name              String
  description       String?
  userId            Int
  createdAt         DateTime         @default(now())
  user              User             @relation("UserProjects", fields: [userId], references: [id])
  projectPatterns   ProjectPattern[]
}

model ProjectPattern {
  id         Int     @id @default(autoincrement())
  projectId  Int
  patternId  Int
  rotX       Float
  rotY       Float
  rotZ       Float
  x          Float
  y          Float
  z          Float
  project    Project @relation(fields: [projectId], references: [id])
  pattern    Pattern @relation(fields: [patternId], references: [id])
}

model Point {
  id         Int     @id @default(autoincrement())
  x          Float
  y          Float
  z          Float
  color      String
  pattern    Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  patternId  Int
}
